{
  "name": "bizflow-backend",
  "version": "1.0.0",
  "description": "BizFlow - Sistema de Gestão Integrado para Pequenas e Médias Empresas",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "debug": "nodemon --inspect server.js",
    "test": "jest --verbose --coverage",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=integration --verbose",
    "test:unit": "jest --testPathPattern=unit --verbose",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:health": "node -e \"require('./src/config/database').checkDatabaseHealth().then(console.log).catch(console.error)\"",
    "db:status": "node -e \"console.log('Database State:', require('./src/config/database').getReadyState())\"",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "docker:build": "docker build -t bizflow-backend .",
    "docker:run": "docker run -p 5000:5000 --env-file .env bizflow-backend",
    "railway:deploy": "npm run lint && npm test && node server.js"
  },
  "keywords": [
    "bizflow",
    "management",
    "erp",
    "crm",
    "inventory",
    "sales",
    "nodejs",
    "express",
    "mongodb",
    "jwt",
    "rest-api"
  ],
  "author": {
    "name": "Victor Ucama",
    "email": "victor.ucama@example.com",
    "url": "https://github.com/victorucama"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/victorucama/bizflow-system"
  },
  "bugs": {
    "url": "https://github.com/victorucama/bizflow-system/issues"
  },
  "homepage": "https://github.com/victorucama/bizflow-system#readme",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.10.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1",
    "multer": "^1.4.4",
    "nodemailer": "^6.9.4",
    "uuid": "^9.0.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "supertest": "^6.3.3",
    "eslint": "^8.47.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jest": "^27.2.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!src/tests/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ]
  },
  "nodemonConfig": {
    "watch": [
      "src",
      "server.js"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules/",
      "coverage/",
      "logs/",
      "uploads/"
    ],
    "exec": "node server.js",
    "env": {
      "NODE_ENV": "development"
    }
  }
}
